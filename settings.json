{
  "model": "deepseek-chat",
  "reasoning_model": "deepseek-reasoner",
  "temperature": 0.0,
  "analysis_temperature": 0.3,
  "max_tokens": 4096,
  "reasoning_max_tokens": 8192,
  "timeout": 60,
  "reasoning_timeout": 120,
  "max_turns": 50,
  "compact_trigger_tokens": 2000000,
  "sessions_dir": "./sessions",
  "skills_dir": "./skills",
  "default_shell": "powershell",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "TodoWrite",
      "Write",
      "Edit",
      "WebFetch",
      "WebSearch",
      "Agent"
    ],
    "ask": [
      "Shell"
    ],
    "deny": [
      "Read(*.pem)",
      "Read(*.key)",
      "Write(*.env*)",
      "Read(*wallet*)",
      "Read(*secret*)",
      "Read(*credential*)",
      "Shell(rm -rf /*)",
      "Shell(del /f C:*)"
    ]
  }
}
